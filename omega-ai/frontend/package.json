{
  "name": "omega-ai-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "wait-on http://localhost:5173 && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "axios": "^1.6.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.omega.ai.desktop",
    "productName": "Omega AI Desktop",
    "icon": "assets/logo.png",
    "linux": {
      "target": ["deb"],
      "category": "Development",
      "icon": "assets/logo.png"
    },
    "deb": {
      "depends": ["gconf2", "libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6"]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/logo.png"
    ]
  }
}
